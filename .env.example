# =============================================================================
# Halo Air — environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# Phase 1 (live now) — Web3Forms booking + contact form delivery
# -----------------------------------------------------------------------------
# Get a free access key at https://web3forms.com (no signup required for the key).
# Used by src/components/BookingForm.astro and src/components/ContactForm.astro.
PUBLIC_WEB3FORMS_KEY=

# -----------------------------------------------------------------------------
# Phase 2 (planned) — AI dispatcher backend
# These are placeholders. They are not read by the Phase 1 static build.
# When the Phase 2 Node API endpoint is stood up, populate these server-side.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
RESEND_API_KEY=
