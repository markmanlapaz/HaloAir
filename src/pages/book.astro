---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import BookingForm from '~/components/BookingForm.astro';
import config from '~/data/business-config.json';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Book a Visit', href: '/book' },
];
---
<BaseLayout
  title="Book a Service Visit — Halo Air Heating & Cooling"
  description={`Request HVAC, plumbing, or gas service from ${config.business.shortName}. Same-day appointments when you book before noon. Serving Edmonton and surrounding areas.`}
  canonicalPath="/book"
  breadcrumbs={breadcrumbs}
>
  <Breadcrumb items={breadcrumbs} class="border-b border-brand-line bg-white" />

  <section class="section">
    <div class="container-wide">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <span class="eyebrow">Book Online</span>
        <h1 class="mt-3 text-4xl font-extrabold tracking-tight sm:text-5xl">
          Schedule a visit
        </h1>
        <p class="mt-4 text-brand-slate">
          Tell us what's going on and we'll confirm your appointment. Most
          non-emergency requests get a callback within two business hours.
        </p>
      </div>
      <BookingForm />
    </div>
  </section>
</BaseLayout>
