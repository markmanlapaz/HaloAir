---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ServiceCard from '~/components/ServiceCard.astro';
import CTABanner from '~/components/CTABanner.astro';
import TrustBadges from '~/components/TrustBadges.astro';
import Logo from '~/components/Logo.astro';
import ServiceBadges from '~/components/ServiceBadges.astro';
import HeroQuickForm from '~/components/HeroQuickForm.astro';
import config from '~/data/business-config.json';

const phone = config.business.phone;
const phoneE164 = config.business.phoneE164;
const cityList = config.serviceAreas.slice(0, 4).join(', ') + ', and more';

// Homepage service grid — three category cards (Heating / Cooling / Water)
// plus the standalone After-Hours card. Each card is the entry-point into a
// topical cluster rather than a leaf page, so the homepage doesn't compete
// with the category landing pages for keywords.
const services = [
  {
    title: 'Heating',
    href: '/services/heating',
    icon: 'flame' as const,
    accent: 'orange' as const,
    description: 'Furnace repair, installation, and seasonal tune-ups — gas work handled by the same crew.',
  },
  {
    title: 'Cooling',
    href: '/services/cooling',
    icon: 'snowflake' as const,
    accent: 'blue' as const,
    description: 'AC repair, new installs, and spring maintenance. Refrigerant-licensed, all major brands.',
  },
  {
    title: 'Water Heaters',
    href: '/services/water',
    icon: 'tools' as const,
    accent: 'blue' as const,
    description: 'Tank, tankless, repair, replace — Red Seal Plumber + Gasfitter handles plumbing and gas on one ticket.',
  },
  {
    title: 'After-Hours Service',
    href: '/services/after-hours',
    icon: 'alert' as const,
    accent: 'orange' as const,
    description: 'No heat or no cool outside normal hours? Call or email and we will work to get to you as soon as possible.',
  },
];

// Homepage Service schema — improves rich-result eligibility for "HVAC near me".
const serviceListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: services.map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Service',
      name: s.title,
      url: `${Astro.site?.toString().replace(/\/$/, '') ?? ''}${s.href}`,
      provider: { '@id': `${Astro.site?.toString().replace(/\/$/, '') ?? ''}/#business` },
    },
  })),
};
---
<BaseLayout
  title="Halo Air Heating & Cooling — Edmonton HVAC, Plumbing & Gas"
  description="Edmonton-based heating, cooling, plumbing and gas specialists. AC repair, furnace service, water heater service, and after-hours service. Award-winning technician with 15 years of experience. Call 780-224-0024."
  canonicalPath="/"
  isHome={true}
  extraSchema={serviceListSchema}
>
  <!-- ==================================================================== -->
  <!-- HERO                                                                  -->
  <!-- ==================================================================== -->
  <section class="relative overflow-hidden bg-brand-blue-900">
    <!-- Hero background photo — responsive variants generated by
         scripts/optimize-hero.mjs from the original public/images/hero-image.jpg.
         Fallback: deep brand-blue-900 on the <section> keeps overlay + white
         text readable if the image fails to load.
         Stacking: DOM order layers picture → gradient → content (which is
         relative z-10). No negative z-indexes — they can hide behind the
         section's own background under some Tailwind compilations. -->
    <picture>
      <source
        type="image/webp"
        srcset="/images/hero-image-1200.webp 1200w, /images/hero-image-2400.webp 2400w"
        sizes="100vw"
      />
      <img
        src="/images/hero-image-1200.jpg"
        srcset="/images/hero-image-1200.jpg 1200w, /images/hero-image-2400.jpg 2400w"
        sizes="100vw"
        alt=""
        aria-hidden="true"
        fetchpriority="high"
        loading="eager"
        decoding="async"
        class="absolute inset-0 h-full w-full object-cover"
      />
    </picture>
    <!-- Brand-tinted radial vignette: lighter at the centre so the photo
         reads through where the eye lands, heavy at the edges to anchor the
         headline copy (left) and the white form card (right) against a deep
         brand-blue wash. brand-blue-900 = #03203F. -->
    <div
      aria-hidden="true"
      class="absolute inset-0"
      style="background: radial-gradient(ellipse at center, rgba(3, 32, 63, 0.55) 0%, rgba(3, 32, 63, 0.72) 55%, rgba(3, 32, 63, 0.94) 100%);"
    ></div>

    <div class="container-wide relative z-10 pt-12 pb-16 sm:pt-20 sm:pb-24 lg:pt-28 lg:pb-32">
      <div class="grid items-center gap-12 lg:grid-cols-[1.1fr_1fr]">
        <div>
          <span class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-white backdrop-blur">
            <span class="h-1.5 w-1.5 rounded-full bg-brand-orange-500 animate-pulse"></span>
            Serving {cityList}
          </span>

          <h1 class="mt-5 text-4xl font-extrabold leading-[1.05] tracking-tight text-white sm:text-5xl lg:text-6xl">
            Next-level <span class="text-brand-blue-100">comfort.</span><br />
            Done <span class="text-brand-orange-100">right.</span>
          </h1>

          <p class="mt-6 max-w-xl text-lg leading-relaxed text-white/90">
            Heating, cooling, plumbing &amp; gas — four trades under one halo.
            Award-winning technician with 15 years of HVAC experience, honest
            pricing, and free estimates on every new equipment install.
          </p>

          <ServiceBadges class="mt-6" on="dark" />

          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/book" class="btn-primary">Book Service</a>
            <a href={`tel:${phoneE164}`} class="btn-ghost">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
              </svg>
              Call {phone}
            </a>
          </div>

          <ul class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm font-medium text-white/90">
            {config.trustSignals.guarantees.map((g) => (
              <li class="flex items-center gap-2">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-orange-500" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {g}
              </li>
            ))}
          </ul>
        </div>

        <!-- Hero inquiry form — quick 3-field lead capture that hands off to
             /book with prefilled values. Brand identity continues to read in
             the header, footer, and "Halo Air Promise" card further down. -->
        <HeroQuickForm />
      </div>
    </div>
  </section>

  <!-- ==================================================================== -->
  <!-- TRUST BADGES                                                          -->
  <!-- ==================================================================== -->
  <TrustBadges />

  <!-- ==================================================================== -->
  <!-- SERVICES OVERVIEW                                                     -->
  <!-- ==================================================================== -->
  <section class="section" id="services">
    <div class="container-wide">
      <div class="mx-auto max-w-2xl text-center">
        <span class="eyebrow">Services</span>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
          One call. Four trades. Zero juggling.
        </h2>
        <p class="mt-3 text-brand-slate">
          From a leaky water heater to a full furnace swap, you don't need
          three contractors. Halo Air handles plumbing, gas, refrigeration
          and air conditioning under one roof.
        </p>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {services.map((s) => (
          <ServiceCard
            title={s.title}
            href={s.href}
            description={s.description}
            icon={s.icon}
            accent={s.accent}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ==================================================================== -->
  <!-- WHY HALO AIR                                                          -->
  <!-- ==================================================================== -->
  <section class="section bg-white border-y border-brand-line">
    <div class="container-wide grid items-center gap-12 lg:grid-cols-2">
      <div>
        <span class="eyebrow">Why Halo Air</span>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
          Built on the standard you'd want in your own home.
        </h2>
        <p class="mt-4 text-brand-slate">
          We're a small Edmonton outfit with full journeyman tickets across
          plumbing, gas, refrigeration and air conditioning. That means one
          accountable team, no sub-contractor finger-pointing, and the same
          quality of work whether we're installing a $12,000 furnace or
          swapping out a $40 pressure-relief valve.
        </p>

        <dl class="mt-8 grid gap-6 sm:grid-cols-2">
          <div>
            <dt class="text-sm font-semibold uppercase tracking-wider text-brand-blue-700">Licensed</dt>
            <dd class="mt-1 text-brand-slate">Journeyman tickets in four trades — held to a higher standard than apprentice-level work.</dd>
          </div>
          <div>
            <dt class="text-sm font-semibold uppercase tracking-wider text-brand-blue-700">Insured</dt>
            <dd class="mt-1 text-brand-slate">Fully insured for your protection and the protection of your home.</dd>
          </div>
          <div>
            <dt class="text-sm font-semibold uppercase tracking-wider text-brand-orange-600">Honest</dt>
            <dd class="mt-1 text-brand-slate">Upfront pricing before work starts. No surprise line-items, no high-pressure upsells.</dd>
          </div>
          <div>
            <dt class="text-sm font-semibold uppercase tracking-wider text-brand-orange-600">Local</dt>
            <dd class="mt-1 text-brand-slate">Edmonton-based, Alberta-tough. We know what −35°C does to furnaces.</dd>
          </div>
        </dl>
      </div>

      <!-- Promise card — brand-led, no individual person -->
      <div class="relative">
        <div class="card !p-0 overflow-hidden">
          <div class="relative aspect-[5/4] bg-gradient-to-br from-brand-blue-700 via-brand-blue-600 to-brand-orange-500 p-8 text-white">
            <span aria-hidden="true" class="absolute -right-12 -top-12 h-48 w-48 rounded-full bg-white/15 blur-3xl"></span>
            <span aria-hidden="true" class="absolute -left-12 -bottom-12 h-48 w-48 rounded-full bg-brand-orange-700/40 blur-3xl"></span>
            <div class="relative flex h-full flex-col justify-between">
              <Logo variant="mark" height={72} on="dark" />
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/75">The Halo Air Promise</p>
                <p class="mt-2 text-2xl font-extrabold leading-tight">
                  If it's not right, we'll make it right — no charge, no argument.
                </p>
              </div>
            </div>
          </div>
          <div class="bg-white p-6 sm:p-8">
            <ul class="space-y-3 text-brand-slate">
              {config.trustSignals.guarantees.map((g) => (
                <li class="flex items-start gap-3">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-brand-blue-600" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  <span class="font-medium text-brand-ink">{g}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================================================================== -->
  <!-- GOOGLE REVIEWS                                                        -->
  <!-- ==================================================================== -->
  <section class="section">
    <div class="container-wide">
      <div class="relative overflow-hidden rounded-[2.5rem] border border-brand-line bg-white p-8 shadow-soft sm:p-12">
        <div class="grid items-center gap-8 lg:grid-cols-[1.2fr_1fr]">
          <div>
            <span class="eyebrow">Loved the service?</span>
            <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
              We'd love a Google review.
            </h2>
            <p class="mt-3 max-w-xl text-brand-slate">
              Honest reviews from neighbours are how local Edmonton families
              find a tradesperson they can trust. If we did right by you,
              we'd genuinely appreciate two minutes of your time.
            </p>
            <a
              href={config.business.googleReviewUrl}
              target="_blank"
              rel="noopener"
              class="btn-secondary mt-6"
            >
              <!-- Google "G" mark — official multi-colour -->
              <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
                <path fill="#FFFFFF" d="M16.51 8.18c0-.57-.05-.99-.16-1.43H9v2.7h4.32c-.09.72-.56 1.82-1.6 2.55l-.01.1 2.32 1.79.16.02c1.48-1.37 2.32-3.38 2.32-5.73z"/>
                <path fill="#FFFFFF" opacity=".85" d="M9 17c2.1 0 3.86-.69 5.15-1.87l-2.45-1.91c-.66.46-1.55.78-2.7.78a4.7 4.7 0 0 1-4.43-3.24l-.09.01-2.42 1.87-.03.09A8 8 0 0 0 9 17z"/>
              </svg>
              Leave a Google review
            </a>
            <p class="mt-3 text-xs text-brand-slate">
              You'll be taken to our Google Business profile in a new tab.
            </p>
          </div>

          <!-- Stylised 5-star card — placeholder for live rating widget if/when added -->
          <div class="rounded-3xl bg-gradient-to-br from-brand-blue-50 to-brand-orange-50 p-8 text-center">
            <div class="flex justify-center gap-1" aria-label="5 out of 5 stars">
              {[0,1,2,3,4].map(() => (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="#F59E0B" aria-hidden="true">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              ))}
            </div>
            <p class="mt-3 text-lg font-bold text-brand-ink">Trusted by Edmonton homeowners</p>
            <p class="mt-1 text-sm text-brand-slate">Read what neighbours are saying on Google.</p>
            <a
              href={config.business.social.google}
              target="_blank"
              rel="noopener"
              class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-brand-blue-700 hover:text-brand-blue-900"
            >
              View our reviews
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================================================================== -->
  <!-- SERVICE AREA                                                          -->
  <!-- ==================================================================== -->
  <section class="section pt-0">
    <div class="container-wide">
      <div class="mx-auto max-w-2xl text-center">
        <span class="eyebrow">Coverage</span>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
          Proudly serving the Edmonton metro.
        </h2>
        <p class="mt-3 text-brand-slate">
          If you're inside Anthony Henday or in one of the bedroom communities,
          we'll be there. No travel surcharges within our service area.
        </p>
      </div>

      <ul class="mt-10 flex flex-wrap justify-center gap-3">
        {config.serviceAreas.map((city) => (
          <li class="rounded-full border border-brand-line bg-white px-5 py-2.5 text-sm font-semibold text-brand-ink shadow-soft">
            {city}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ==================================================================== -->
  <!-- FINAL CTA                                                             -->
  <!-- ==================================================================== -->
  <CTABanner
    heading="Comfort issue? Let's get it sorted."
    subheading={`Call ${phone} or book in under a minute. After-hours service is available on request — we'll be in touch within one business day.`}
  />
</BaseLayout>
