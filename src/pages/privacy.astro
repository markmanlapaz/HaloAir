---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import config from '~/data/business-config.json';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Privacy', href: '/privacy' },
];

const lastUpdated = '2026-05-17';
---
<BaseLayout
  title="Privacy Policy — Halo Air Heating & Cooling"
  description="How Halo Air collects, uses, and protects your personal information. PIPEDA-compliant policy for Alberta residents."
  canonicalPath="/privacy"
  breadcrumbs={breadcrumbs}
>
  <Breadcrumb items={breadcrumbs} class="border-b border-brand-line bg-white" />

  <section class="section">
    <div class="container-wide max-w-3xl">
      <span class="eyebrow">Legal</span>
      <h1 class="mt-4 text-4xl font-extrabold tracking-tight sm:text-5xl">Privacy Policy</h1>
      <p class="mt-3 text-sm text-brand-slate">Last updated: {lastUpdated}</p>

      <div class="prose-body mt-10">
        <p>
          Halo Air Heating &amp; Cooling Ltd. ("Halo Air", "we", "us", "our")
          is committed to protecting your privacy. This policy explains what
          personal information we collect, how we use it, and your rights as a
          customer or visitor — in plain language, no legalese.
        </p>

        <h2>What we collect</h2>
        <p>When you submit a booking or contact form on this site, we collect:</p>
        <ul>
          <li>Your name</li>
          <li>Phone number</li>
          <li>Email address</li>
          <li>Service address (booking form only)</li>
          <li>Details of your service request or message</li>
          <li>A booking ID generated for tracking purposes (booking form only)</li>
        </ul>
        <p>
          We do <strong>not</strong> use cookies for advertising or tracking.
          We do not use third-party analytics that profile users. Standard web
          server logs may record your IP address and browser type for the
          purpose of operating the site (security, debugging) — this data is
          retained for 90 days and not shared.
        </p>

        <h2>How we use your information</h2>
        <p>
          We use the information you provide solely to:
        </p>
        <ul>
          <li>Respond to your booking or message</li>
          <li>Schedule and complete service work you requested</li>
          <li>Invoice and process payment for work performed</li>
          <li>Follow up on warranty work and customer satisfaction</li>
          <li>Comply with our legal obligations (permit records, tax records)</li>
        </ul>

        <h2>How we share your information</h2>
        <p>
          We do not sell, rent, or trade your information. We share it only with:
        </p>
        <ul>
          <li><strong>Form processing provider</strong> — currently Web3Forms, which transmits your form submission to our email. Their <a href="https://web3forms.com/privacy" target="_blank" rel="noopener">privacy policy</a> applies to the transmission.</li>
          <li><strong>Government bodies</strong> when required for permits or tax compliance (City of Edmonton, Strathcona County, Canada Revenue Agency, etc.)</li>
          <li><strong>Equipment manufacturers</strong> for warranty registration on equipment we install for you</li>
          <li><strong>Service providers</strong> (e.g. accounting software, payment processors) that operate under strict confidentiality</li>
        </ul>

        <h2>How we protect your information</h2>
        <p>
          Form submissions are transmitted over HTTPS-encrypted connections.
          Customer records are stored in business systems with access limited
          to authorized Halo Air staff. Paper records (where used) are stored
          in a locked filing cabinet.
        </p>

        <h2>Your rights under PIPEDA</h2>
        <p>
          Under Canada's Personal Information Protection and Electronic
          Documents Act (PIPEDA), you have the right to:
        </p>
        <ul>
          <li>Know what personal information we hold about you</li>
          <li>Request a copy of your personal information</li>
          <li>Request correction of inaccurate information</li>
          <li>Withdraw consent for our use of your information (subject to legal/contractual exceptions)</li>
          <li>File a complaint with the Office of the Privacy Commissioner of Canada</li>
        </ul>
        <p>
          To exercise any of these rights, contact us at <a href={`mailto:${config.business.email}`}>{config.business.email}</a> or call {config.business.phone}.
        </p>

        <h2>Retention</h2>
        <p>
          We retain customer records for the longer of (a) 7 years for tax
          compliance under Canadian law, or (b) the warranty period applicable
          to work performed for you (typically 10 years for equipment we install).
          Web server logs are retained for 90 days.
        </p>

        <h2>Changes to this policy</h2>
        <p>
          We may update this privacy policy as our practices evolve or as
          required by law. The "Last updated" date at the top of this page
          reflects the most recent change. Material changes will be
          communicated to active customers by email.
        </p>

        <h2>Contact us</h2>
        <p>
          Questions about this privacy policy? Reach out:
        </p>
        <ul>
          <li>Email: <a href={`mailto:${config.business.email}`}>{config.business.email}</a></li>
          <li>Phone: <a href={`tel:${config.business.phoneE164}`}>{config.business.phone}</a></li>
          <li>Mail: Halo Air Heating &amp; Cooling Ltd., Edmonton, AB</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .prose-body :global(h2) {
    font-size: 1.5rem; font-weight: 800; color: #0E1320; margin: 2rem 0 0.75rem;
  }
  .prose-body :global(p), .prose-body :global(li) {
    font-size: 1rem; line-height: 1.7; color: #3A4256;
  }
  .prose-body :global(p) { margin: 0 0 1rem; }
  .prose-body :global(ul) { padding-left: 1.5rem; margin: 0 0 1.25rem; }
  .prose-body :global(li) { margin: 0 0 0.4rem; }
  .prose-body :global(a) {
    color: #0858AC; font-weight: 600; text-decoration: underline; text-underline-offset: 3px;
  }
  .prose-body :global(strong) { color: #0E1320; font-weight: 700; }
</style>
