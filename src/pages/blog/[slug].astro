---
// =============================================================================
// /blog/[slug] — dynamic blog post page
// =============================================================================
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import CTABanner from '~/components/CTABanner.astro';
import config from '~/data/business-config.json';
import { articleSchema, faqPageSchema } from '~/lib/schema';

export async function getStaticPaths() {
  const entries = await getCollection('blog');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const post = { ...entry.data, slug: entry.id };
const { Content } = await render(entry);

// Related posts — same tags, excluding self, up to 3
const allBlog = await getCollection('blog');
const related = allBlog
  .filter((p) => p.id !== entry.id)
  .filter((p) => p.data.tags.some((t) => post.tags.includes(t)))
  .sort((a, b) => (a.data.publishedAt > b.data.publishedAt ? -1 : 1))
  .slice(0, 3)
  .map((p) => ({ ...p.data, slug: p.id }));

const extraSchema: Record<string, unknown>[] = [
  articleSchema(Astro.site, {
    title: post.title,
    description: post.metaDesc,
    slug: post.slug,
    publishedAt: post.publishedAt,
    updatedAt: post.updatedAt,
  }),
];
if (post.faq.length > 0) {
  extraSchema.push(faqPageSchema(post.faq));
}

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Blog', href: '/blog' },
  { name: post.title, href: `/blog/${post.slug}` },
];

const publishedDate = new Date(post.publishedAt).toLocaleDateString('en-CA', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const updatedDate = post.updatedAt
  ? new Date(post.updatedAt).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
---
<BaseLayout
  title={post.metaTitle}
  description={post.metaDesc}
  canonicalPath={`/blog/${post.slug}`}
  breadcrumbs={breadcrumbs}
  extraSchema={extraSchema}
>
  <Breadcrumb items={breadcrumbs} class="border-b border-brand-line bg-white" />

  <article class="section">
    <div class="container-wide max-w-3xl">
      <!-- Post header -->
      <header>
        <div class="flex flex-wrap items-center gap-2 text-sm text-brand-slate">
          <time datetime={post.publishedAt}>{publishedDate}</time>
          {post.tags.length > 0 && (
            <>
              <span aria-hidden="true">·</span>
              <ul class="flex flex-wrap gap-2">
                {post.tags.map((t) => (
                  <li class="rounded-full bg-brand-blue-50 px-2.5 py-0.5 text-xs font-semibold text-brand-blue-700">
                    {t}
                  </li>
                ))}
              </ul>
            </>
          )}
        </div>
        <h1 class="mt-4 text-4xl font-extrabold leading-[1.1] tracking-tight sm:text-5xl">
          {post.title}
        </h1>
        <p class="mt-5 text-xl leading-relaxed text-brand-slate">
          {post.excerpt}
        </p>
        {updatedDate && (
          <p class="mt-4 text-xs text-brand-slate">Last updated: {updatedDate}</p>
        )}
      </header>

      <!-- Markdown body -->
      <div class="prose-body mt-12">
        <Content />
      </div>

      <!-- FAQ section -->
      {post.faq.length > 0 && (
        <section class="mt-14 rounded-2xl border border-brand-line bg-white p-6 sm:p-8">
          <h2 class="text-2xl font-extrabold tracking-tight">Frequently asked questions</h2>
          <div class="mt-6 space-y-3">
            {post.faq.map((f) => (
              <details class="group rounded-xl border border-brand-line bg-brand-cream/50 p-5">
                <summary class="flex cursor-pointer items-start justify-between gap-4 text-base font-semibold text-brand-ink">
                  <span>{f.q}</span>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 transition-transform group-open:rotate-180" aria-hidden="true">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </summary>
                <p class="mt-3 leading-relaxed text-brand-slate">{f.a}</p>
              </details>
            ))}
          </div>
        </section>
      )}

      <!-- Inline CTA -->
      <div class="mt-14 rounded-2xl bg-gradient-to-br from-brand-blue-700 to-brand-orange-500 p-8 text-white">
        <h2 class="text-2xl font-extrabold">Have a question on this?</h2>
        <p class="mt-2 text-white/85">
          Call {config.business.phone} or book online — we answer the phone and we'll diagnose the issue specific to your home.
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a href="/book" class="btn-primary !bg-white !text-brand-orange-600 hover:!bg-brand-cream">Book a visit</a>
          <a href={`tel:${config.business.phoneE164}`} class="btn-ghost !border-white/30 !bg-white/10 !text-white hover:!bg-white/20">Call {config.business.phone}</a>
        </div>
      </div>
    </div>
  </article>

  <!-- Related posts -->
  {related.length > 0 && (
    <section class="section bg-white border-t border-brand-line">
      <div class="container-wide max-w-5xl">
        <span class="eyebrow">Related reading</span>
        <h2 class="mt-3 text-2xl font-extrabold tracking-tight sm:text-3xl">More from the Halo Air blog</h2>
        <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {related.map((p) => (
            <a href={`/blog/${p.slug}`} class="group flex h-full flex-col rounded-2xl border border-brand-line bg-white p-6 shadow-soft transition-all hover:-translate-y-1 hover:shadow-glow-blue">
              <p class="text-xs font-semibold uppercase tracking-wider text-brand-blue-700">{p.tags[0]}</p>
              <h3 class="mt-3 text-lg font-bold leading-snug">{p.title}</h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-brand-slate">{p.excerpt}</p>
              <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-blue-700 group-hover:gap-2 transition-all">
                Read more
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTABanner />
</BaseLayout>

<style>
  .prose-body :global(h2) {
    font-size: 1.875rem; line-height: 1.15; font-weight: 800; letter-spacing: -0.02em;
    color: #0E1320; margin: 2.5rem 0 1rem;
  }
  .prose-body :global(h3) {
    font-size: 1.375rem; line-height: 1.25; font-weight: 700; letter-spacing: -0.01em;
    color: #0E1320; margin: 2rem 0 0.75rem;
  }
  .prose-body :global(h4) {
    font-size: 1.125rem; font-weight: 700; color: #0E1320; margin: 1.5rem 0 0.5rem;
  }
  .prose-body :global(p) {
    font-size: 1.0625rem; line-height: 1.75; color: #3A4256; margin: 0 0 1.25rem;
  }
  .prose-body :global(ul), .prose-body :global(ol) {
    padding-left: 1.5rem; margin: 0 0 1.25rem;
    font-size: 1.0625rem; line-height: 1.7; color: #3A4256;
  }
  .prose-body :global(li) { margin: 0 0 0.5rem; }
  .prose-body :global(a) {
    color: #0858AC; font-weight: 600; text-decoration: underline; text-underline-offset: 3px;
  }
  .prose-body :global(strong) { color: #0E1320; font-weight: 700; }
  .prose-body :global(table) {
    width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.9375rem;
  }
  .prose-body :global(th), .prose-body :global(td) {
    border: 1px solid #E6E1D8; padding: 0.625rem 0.875rem; text-align: left; vertical-align: top;
  }
  .prose-body :global(th) { background: #FAF7F2; font-weight: 700; color: #0E1320; }
  .prose-body :global(hr) { border: 0; border-top: 1px solid #E6E1D8; margin: 2rem 0; }
  .prose-body :global(blockquote) {
    border-left: 3px solid #1E90FF; padding-left: 1.25rem; margin: 1.5rem 0;
    color: #3A4256; font-style: italic;
  }
</style>
