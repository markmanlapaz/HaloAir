---
// =============================================================================
// /blog — blog hub
// =============================================================================
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import CTABanner from '~/components/CTABanner.astro';

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a, b) => (a.data.publishedAt > b.data.publishedAt ? -1 : 1))
  .map((p) => ({ ...p.data, slug: p.id }));

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Blog', href: '/blog' },
];
---
<BaseLayout
  title="HVAC, Furnace & Water Heater Guides — Halo Air Blog"
  description="Practical HVAC, furnace, and water heater guides for Edmonton homeowners. Cost breakdowns, rebate info, decision frameworks, and seasonal checklists from a licensed local team."
  canonicalPath="/blog"
  breadcrumbs={breadcrumbs}
>
  <Breadcrumb items={breadcrumbs} class="border-b border-brand-line bg-white" />

  <section class="section pt-12">
    <div class="container-wide">
      <div class="mx-auto max-w-3xl text-center">
        <span class="eyebrow">Halo Air Blog</span>
        <h1 class="mt-4 text-4xl font-extrabold tracking-tight sm:text-5xl">
          Honest guides for Edmonton homeowners.
        </h1>
        <p class="mt-5 text-lg text-brand-slate">
          No fluff, no SEO filler — just the answers we'd give a neighbour over
          coffee. Cost guides, rebate info, decision frameworks, and the
          checklists we use on real calls.
        </p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((p) => (
          <a
            href={`/blog/${p.slug}`}
            class="group flex h-full flex-col rounded-3xl border border-brand-line bg-white p-6 shadow-soft transition-all duration-200 hover:-translate-y-1 hover:shadow-glow-blue sm:p-8"
          >
            <div class="flex flex-wrap gap-1.5">
              {p.tags.slice(0, 2).map((t) => (
                <span class="rounded-full bg-brand-blue-50 px-2.5 py-0.5 text-xs font-semibold text-brand-blue-700">{t}</span>
              ))}
            </div>
            <h2 class="mt-4 text-xl font-bold leading-snug tracking-tight">{p.title}</h2>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-brand-slate">{p.excerpt}</p>
            <time datetime={p.publishedAt} class="mt-5 text-xs font-medium uppercase tracking-wider text-brand-slate">
              {new Date(p.publishedAt).toLocaleDateString('en-CA', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    heading="Have a question we haven't covered?"
    subheading="Call 780-224-0024 or book online — we're glad to talk through your situation."
  />
</BaseLayout>
