---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ContactForm from '~/components/ContactForm.astro';
import config from '~/data/business-config.json';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Contact', href: '/contact' },
];

// ContactPoint schema for AI Overviews / Knowledge Panel surfacing
const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  mainEntity: {
    '@type': 'Organization',
    '@id': `${(Astro.site?.toString() ?? 'https://example.com').replace(/\/$/, '')}/#business`,
    name: config.business.name,
    contactPoint: [
      {
        '@type': 'ContactPoint',
        telephone: config.business.phoneE164,
        contactType: 'customer service',
        areaServed: 'CA-AB',
        availableLanguage: ['English'],
        hoursAvailable: [
          { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday'], opens: '08:00', closes: '17:00' },
        ],
      },
    ],
  },
};
---
<BaseLayout
  title="Contact Halo Air Heating & Cooling — Edmonton HVAC"
  description="Call 780-224-0024 weekdays 8am–5pm, or send us a message anytime. Edmonton HVAC, plumbing, gas, refrigeration. After-hours service available on request."
  canonicalPath="/contact"
  breadcrumbs={breadcrumbs}
  extraSchema={contactSchema}
>
  <Breadcrumb items={breadcrumbs} class="border-b border-brand-line bg-white" />

  <section class="section pt-12">
    <div class="container-wide">
      <div class="grid gap-12 lg:grid-cols-[1fr_1.2fr]">
        <!-- Contact info column -->
        <div>
          <span class="eyebrow">Contact</span>
          <h1 class="mt-4 text-4xl font-extrabold leading-[1.05] tracking-tight sm:text-5xl">
            Get in touch with Halo Air.
          </h1>
          <p class="mt-4 text-lg text-brand-slate">
            For service bookings, use the <a href="/book" class="font-semibold text-brand-blue-700 hover:underline">booking form</a>.
            For general questions, the form below or any of the channels here works.
          </p>

          <div class="mt-8 space-y-5">
            <a href={`tel:${config.business.phoneE164}`} class="flex items-center gap-4 rounded-2xl border border-brand-line bg-white p-5 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-glow-blue">
              <span class="grid h-12 w-12 place-items-center rounded-full bg-brand-orange-500 text-white">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
                </svg>
              </span>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-brand-slate">Call / text</p>
                <p class="text-xl font-bold text-brand-ink">{config.business.phone}</p>
                <p class="text-sm text-brand-slate">After-hours service available on request</p>
              </div>
            </a>

            <a href={`mailto:${config.business.email}`} class="flex items-center gap-4 rounded-2xl border border-brand-line bg-white p-5 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-glow-blue">
              <span class="grid h-12 w-12 place-items-center rounded-full bg-brand-blue-600 text-white">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </span>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-brand-slate">Email</p>
                <p class="text-xl font-bold text-brand-ink">{config.business.email}</p>
                <p class="text-sm text-brand-slate">Reply within 1 business day</p>
              </div>
            </a>

            <div class="rounded-2xl border border-brand-line bg-white p-5">
              <p class="text-xs font-semibold uppercase tracking-wider text-brand-slate">Hours</p>
              <dl class="mt-2 space-y-1.5 text-sm">
                <div class="flex justify-between"><dt class="text-brand-slate">Mon–Fri</dt><dd class="font-semibold text-brand-ink">8:00am – 5:00pm</dd></div>
                <div class="flex justify-between"><dt class="text-brand-slate">Saturday</dt><dd class="font-semibold text-brand-ink">Closed</dd></div>
                <div class="flex justify-between"><dt class="text-brand-slate">Sunday</dt><dd class="font-semibold text-brand-ink">Closed</dd></div>
                <div class="mt-2 flex justify-between border-t border-brand-line pt-2"><dt class="font-semibold text-brand-orange-600">After-hours</dt><dd class="font-bold text-brand-orange-600">By request</dd></div>
              </dl>
              <p class="mt-3 text-xs text-brand-slate">Need help outside business hours? Call or email — we'll get back to you as soon as we can.</p>
            </div>

            <div class="rounded-2xl bg-brand-cream/60 p-5">
              <p class="text-xs font-semibold uppercase tracking-wider text-brand-slate">Service area</p>
              <p class="mt-2 text-sm text-brand-slate">
                {config.serviceAreas.join(' · ')}
              </p>
            </div>
          </div>
        </div>

        <!-- Form column -->
        <div>
          <ContactForm />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
