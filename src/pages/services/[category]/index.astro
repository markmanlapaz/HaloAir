---
// =============================================================================
// /services/[category] — service category landing page (Heating / Cooling / Water)
//
// Renders each entry in the `serviceCategories` content collection with the
// category-specific intro and three sub-service cards beneath. The category
// itself emits Service + FAQPage + BreadcrumbList JSON-LD via BaseLayout.
// =============================================================================
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ServiceCard from '~/components/ServiceCard.astro';
import CTABanner from '~/components/CTABanner.astro';
import TrustBadges from '~/components/TrustBadges.astro';
import config from '~/data/business-config.json';
import { serviceSchema, faqPageSchema } from '~/lib/schema';

export async function getStaticPaths() {
  const cats = await getCollection('serviceCategories');
  return cats.map((entry) => ({
    params: { category: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const category = entry.id;
const cat = entry.data;
const { Content } = await render(entry);

// Sub-services for this category — sorted by `order`.
const allServices = await getCollection('services');
const subServices = allServices
  .filter((s) => s.id.startsWith(`${category}/`))
  .sort((a, b) => a.data.order - b.data.order)
  .map((s) => {
    const [, sSlug] = s.id.split('/');
    return { ...s.data, slug: sSlug, category };
  });

const extraSchema: Record<string, unknown>[] = [
  serviceSchema(Astro.site, {
    name: cat.label,
    description: cat.metaDesc,
    slug: category,
    serviceType: cat.label,
  }),
];
if (cat.faq.length > 0) {
  extraSchema.push(faqPageSchema(cat.faq));
}

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Services', href: '/services' },
  { name: cat.label, href: `/services/${category}` },
];
---
<BaseLayout
  title={cat.metaTitle}
  description={cat.metaDesc}
  canonicalPath={`/services/${category}`}
  breadcrumbs={breadcrumbs}
  extraSchema={extraSchema}
>
  <Breadcrumb items={breadcrumbs} class="border-b border-brand-line bg-white" />

  <!-- HERO -->
  <section class="section pt-12">
    <div class="container-wide">
      <div class="grid items-center gap-10 lg:grid-cols-[1.2fr_1fr]">
        <div>
          <span class={`eyebrow ${cat.accent === 'orange' ? '!bg-brand-orange-50 !text-brand-orange-700' : ''}`}>
            {cat.label}
          </span>
          <h1 class="mt-4 text-4xl font-extrabold leading-[1.05] tracking-tight sm:text-5xl lg:text-[3.5rem]">
            {cat.h1}
          </h1>
          <p class="mt-5 max-w-xl text-lg leading-relaxed text-brand-slate">
            {cat.intro}
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/book" class="btn-primary">Book a visit</a>
            <a href={`tel:${config.business.phoneE164}`} class="btn-ghost">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
              </svg>
              Call {config.business.phone}
            </a>
          </div>
        </div>

        <!-- Hero accent panel — gradient card with category icon -->
        <div class={`relative aspect-[4/5] rounded-[2rem] p-8 text-white shadow-soft ${cat.accent === 'orange' ? 'bg-gradient-to-br from-brand-orange-600 via-brand-orange-500 to-brand-ink' : 'bg-gradient-to-br from-brand-blue-700 via-brand-blue-600 to-brand-ink'}`}>
          <span aria-hidden="true" class="absolute -top-10 -right-10 h-48 w-48 rounded-full bg-white/15 blur-3xl"></span>
          <span aria-hidden="true" class="absolute -bottom-10 -left-10 h-48 w-48 rounded-full bg-black/30 blur-3xl"></span>
          <div class="relative flex h-full flex-col justify-between">
            <span class="grid h-16 w-16 place-items-center rounded-2xl bg-white/15 backdrop-blur-sm">
              {cat.icon === 'snowflake' && (
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="5" y1="5" x2="19" y2="19"/><line x1="19" y1="5" x2="5" y2="19"/></svg>
              )}
              {cat.icon === 'flame' && (
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
              )}
              {cat.icon === 'thermo' && (
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/></svg>
              )}
              {cat.icon === 'tools' && (
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
              )}
              {cat.icon === 'alert' && (
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              )}
            </span>
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/75">Halo Air</p>
              <p class="mt-2 text-3xl font-extrabold leading-tight">{cat.label}</p>
              <p class="mt-3 text-white/85">{cat.short}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SUB-SERVICES GRID -->
  {subServices.length > 0 && (
    <section class="section">
      <div class="container-wide">
        <span class="eyebrow">{cat.label} services</span>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
          Pick the {cat.label.toLowerCase()} service you need
        </h2>
        <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {subServices.map((s) => (
            <ServiceCard
              title={s.title}
              href={`/services/${s.category}/${s.slug}`}
              description={s.short}
              icon={s.icon}
              accent={s.accent}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- MARKDOWN BODY -->
  <section class="section bg-white border-y border-brand-line pt-12">
    <div class="container-wide max-w-4xl">
      <article class="prose-body">
        <Content />
      </article>
    </div>
  </section>

  <!-- TRUST BADGES -->
  <TrustBadges />

  <!-- FAQ -->
  {cat.faq.length > 0 && (
    <section class="section">
      <div class="container-wide max-w-4xl">
        <span class="eyebrow">FAQ</span>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
          {cat.label} — common questions
        </h2>
        <div class="mt-10 space-y-4">
          {cat.faq.map((f) => (
            <details class="group rounded-2xl border border-brand-line bg-white p-6 shadow-sm">
              <summary class="flex cursor-pointer items-start justify-between gap-4 text-lg font-semibold text-brand-ink">
                <span>{f.q}</span>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-1 shrink-0 transition-transform group-open:rotate-180" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </summary>
              <p class="mt-4 leading-relaxed text-brand-slate">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- SERVICE AREA -->
  <section class="section">
    <div class="container-wide max-w-4xl text-center">
      <span class="eyebrow">Coverage</span>
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
        We serve the entire Edmonton metro
      </h2>
      <ul class="mt-8 flex flex-wrap justify-center gap-3">
        {config.serviceAreas.map((city) => {
          const citySlug = city.toLowerCase().replace(/\./g, '').replace(/\s+/g, '-');
          return (
            <li>
              <a href={`/service-areas/${citySlug}`} class="inline-flex items-center rounded-full border border-brand-line bg-white px-5 py-2.5 text-sm font-semibold text-brand-ink shadow-soft transition-colors hover:bg-brand-blue-50 hover:text-brand-blue-700">
                {city}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </section>

  <!-- FINAL CTA -->
  <CTABanner
    heading={`Ready to book a ${cat.label.toLowerCase()} visit?`}
    subheading={`Call ${config.business.phone} or book online — we'll be in touch within one business day.`}
  />
</BaseLayout>

<style>
  .prose-body :global(h2) {
    font-size: 1.875rem; line-height: 1.15; font-weight: 800; letter-spacing: -0.02em;
    color: #0E1320; margin: 2rem 0 1rem;
  }
  .prose-body :global(h3) {
    font-size: 1.375rem; line-height: 1.25; font-weight: 700; letter-spacing: -0.01em;
    color: #0E1320; margin: 1.75rem 0 0.75rem;
  }
  .prose-body :global(p) {
    font-size: 1.0625rem; line-height: 1.7; color: #3A4256; margin: 0 0 1rem;
  }
  .prose-body :global(ul), .prose-body :global(ol) {
    padding-left: 1.5rem; margin: 0 0 1.25rem;
    font-size: 1.0625rem; line-height: 1.7; color: #3A4256;
  }
  .prose-body :global(li) { margin: 0 0 0.5rem; }
  .prose-body :global(a) {
    color: #0858AC; font-weight: 600; text-decoration: underline; text-underline-offset: 3px;
  }
  .prose-body :global(a:hover) { color: #03203F; }
  .prose-body :global(strong) { color: #0E1320; font-weight: 700; }
</style>
