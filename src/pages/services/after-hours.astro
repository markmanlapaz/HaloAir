---
// =============================================================================
// /services/after-hours — standalone service page (cross-category)
//
// After-hours doesn't fit cleanly under Heating / Cooling / Water — it's a
// posture, not a trade — so it lives at the top level of /services/ instead of
// nested under a category. Pulls content from the same `services` collection
// (id = "after-hours", no slash) so the markdown body and FAQ are authored
// the same way as every other service.
// =============================================================================
import { getEntry, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import CTABanner from '~/components/CTABanner.astro';
import TrustBadges from '~/components/TrustBadges.astro';
import config from '~/data/business-config.json';
import { serviceSchema, faqPageSchema } from '~/lib/schema';

const entry = await getEntry('services', 'after-hours');
if (!entry) throw new Error('Missing services collection entry: after-hours');
const service = entry.data;
const { Content } = await render(entry);

const extraSchema: Record<string, unknown>[] = [
  serviceSchema(Astro.site, {
    name: service.title,
    description: service.metaDesc,
    slug: 'after-hours',
    serviceType: service.title,
  }),
];
if (service.faq.length > 0) {
  extraSchema.push(faqPageSchema(service.faq));
}

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Services', href: '/services' },
  { name: service.title, href: '/services/after-hours' },
];
---
<BaseLayout
  title={service.metaTitle}
  description={service.metaDesc}
  canonicalPath="/services/after-hours"
  breadcrumbs={breadcrumbs}
  extraSchema={extraSchema}
>
  <Breadcrumb items={breadcrumbs} class="border-b border-brand-line bg-white" />

  <!-- HERO -->
  <section class="section pt-12">
    <div class="container-wide">
      <div class="grid items-center gap-10 lg:grid-cols-[1.2fr_1fr]">
        <div>
          <span class="eyebrow !bg-brand-orange-50 !text-brand-orange-700">
            {service.title}
          </span>
          <h1 class="mt-4 text-4xl font-extrabold leading-[1.05] tracking-tight sm:text-5xl lg:text-[3.5rem]">
            {service.h1}
          </h1>
          <p class="mt-5 max-w-xl text-lg leading-relaxed text-brand-slate">
            {service.metaDesc}
          </p>

          {service.features.length > 0 && (
            <ul class="mt-6 grid gap-2 sm:grid-cols-2">
              {service.features.map((f) => (
                <li class="flex items-start gap-2 text-sm">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-brand-orange-600" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  <span class="text-brand-ink">{f}</span>
                </li>
              ))}
            </ul>
          )}

          <div class="mt-8 flex flex-wrap gap-3">
            <a href={`tel:${config.business.phoneE164}`} class="btn-primary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
              </svg>
              Call {config.business.phone}
            </a>
            <a href="/book" class="btn-ghost">Book online</a>
          </div>
        </div>

        <div class="relative aspect-[4/5] rounded-[2rem] p-8 text-white shadow-soft bg-gradient-to-br from-brand-orange-600 via-brand-orange-500 to-brand-ink">
          <span aria-hidden="true" class="absolute -top-10 -right-10 h-48 w-48 rounded-full bg-white/15 blur-3xl"></span>
          <span aria-hidden="true" class="absolute -bottom-10 -left-10 h-48 w-48 rounded-full bg-black/30 blur-3xl"></span>
          <div class="relative flex h-full flex-col justify-between">
            <span class="grid h-16 w-16 place-items-center rounded-2xl bg-white/15 backdrop-blur-sm">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </span>
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/75">Halo Air</p>
              <p class="mt-2 text-3xl font-extrabold leading-tight">{service.title}</p>
              <p class="mt-3 text-white/85">{service.short}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MARKDOWN BODY -->
  <section class="section bg-white border-y border-brand-line">
    <div class="container-wide max-w-4xl">
      <article class="prose-body">
        <Content />
      </article>
    </div>
  </section>

  <TrustBadges />

  {service.faq.length > 0 && (
    <section class="section">
      <div class="container-wide max-w-4xl">
        <span class="eyebrow">FAQ</span>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
          {service.title} — common questions
        </h2>
        <div class="mt-10 space-y-4">
          {service.faq.map((f) => (
            <details class="group rounded-2xl border border-brand-line bg-white p-6 shadow-sm">
              <summary class="flex cursor-pointer items-start justify-between gap-4 text-lg font-semibold text-brand-ink">
                <span>{f.q}</span>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-1 shrink-0 transition-transform group-open:rotate-180" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </summary>
              <p class="mt-4 leading-relaxed text-brand-slate">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTABanner
    heading="Need help right now?"
    subheading={`Call ${config.business.phone} — for active emergencies, leave the building first if it's a gas leak or CO alarm, then call from outside.`}
  />
</BaseLayout>

<style>
  .prose-body :global(h2) { font-size: 1.875rem; line-height: 1.15; font-weight: 800; letter-spacing: -0.02em; color: #0E1320; margin: 2rem 0 1rem; }
  .prose-body :global(h3) { font-size: 1.375rem; line-height: 1.25; font-weight: 700; letter-spacing: -0.01em; color: #0E1320; margin: 1.75rem 0 0.75rem; }
  .prose-body :global(p) { font-size: 1.0625rem; line-height: 1.7; color: #3A4256; margin: 0 0 1rem; }
  .prose-body :global(ul), .prose-body :global(ol) { padding-left: 1.5rem; margin: 0 0 1.25rem; font-size: 1.0625rem; line-height: 1.7; color: #3A4256; }
  .prose-body :global(li) { margin: 0 0 0.5rem; }
  .prose-body :global(a) { color: #0858AC; font-weight: 600; text-decoration: underline; text-underline-offset: 3px; }
  .prose-body :global(strong) { color: #0E1320; font-weight: 700; }
</style>
