---
// =============================================================================
// /service-areas/[city] — dynamic city landing page
// Renders each entry in the `cities` content collection at its own URL.
// Emits city-scoped LocalBusiness + FAQPage + BreadcrumbList schema.
// =============================================================================
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ServiceCard from '~/components/ServiceCard.astro';
import CTABanner from '~/components/CTABanner.astro';
import config from '~/data/business-config.json';
import { cityLocalBusinessSchema, faqPageSchema } from '~/lib/schema';

export async function getStaticPaths() {
  const entries = await getCollection('cities');
  return entries.map((entry) => ({
    params: { city: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const city = { ...entry.data, slug: entry.id };
const { Content } = await render(entry);

// Other cities for cross-linking
const allCities = await getCollection('cities');
const otherCities = allCities
  .filter((c) => c.id !== entry.id)
  .sort((a, b) => a.data.order - b.data.order)
  .map((c) => ({ ...c.data, slug: c.id }));

// Services to surface on the page
const allServices = await getCollection('services');
const services = allServices
  .sort((a, b) => a.data.order - b.data.order)
  .map((s) => ({ ...s.data, slug: s.id }));

// Schema
const extraSchema: Record<string, unknown>[] = [
  cityLocalBusinessSchema(Astro.site, city.name, city.slug),
];
if (city.faq.length > 0) {
  extraSchema.push(faqPageSchema(city.faq));
}

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Service Areas', href: '/service-areas' },
  { name: city.name, href: `/service-areas/${city.slug}` },
];
---
<BaseLayout
  title={city.metaTitle}
  description={city.metaDesc}
  canonicalPath={`/service-areas/${city.slug}`}
  breadcrumbs={breadcrumbs}
  extraSchema={extraSchema}
>
  <Breadcrumb items={breadcrumbs} class="border-b border-brand-line bg-white" />

  <!-- HERO -->
  <section class="section pt-12">
    <div class="container-wide">
      <div class="grid items-center gap-10 lg:grid-cols-[1.3fr_1fr]">
        <div>
          <span class="eyebrow">
            <span class="h-1.5 w-1.5 rounded-full bg-brand-blue-600"></span>
            {city.name}, Alberta
          </span>
          <h1 class="mt-4 text-4xl font-extrabold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
            HVAC, plumbing &amp; gas <br/>
            in <span class="text-brand-blue-700">{city.name}</span>.
          </h1>
          <p class="mt-5 max-w-xl text-lg leading-relaxed text-brand-slate">
            {city.intro}
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="/book" class="btn-primary">Book a {city.name} visit</a>
            <a href={`tel:${config.business.phoneE164}`} class="btn-ghost">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
              </svg>
              {config.business.phone}
            </a>
          </div>
        </div>

        <!-- City info card -->
        <div class="card bg-gradient-to-br from-brand-blue-700 via-brand-blue-600 to-brand-orange-500 !border-0 text-white">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/75">Coverage area</p>
          <p class="mt-2 text-2xl font-extrabold leading-tight">{city.name}, AB</p>
          {city.population && (
            <p class="mt-1 text-sm text-white/75">Population: ~{city.population.toLocaleString()}</p>
          )}
          {city.neighborhoods.length > 0 && (
            <>
              <p class="mt-5 text-xs font-semibold uppercase tracking-wider text-white/80">Neighbourhoods we cover</p>
              <ul class="mt-3 flex flex-wrap gap-1.5">
                {city.neighborhoods.map((n) => (
                  <li class="rounded-full bg-white/15 px-3 py-1 text-xs font-semibold backdrop-blur-sm">{n}</li>
                ))}
              </ul>
            </>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- PERMIT NOTE -->
  <section class="section bg-white border-y border-brand-line py-16">
    <div class="container-wide max-w-4xl">
      <span class="eyebrow !bg-brand-orange-50 !text-brand-orange-700">Permits &amp; rules</span>
      <h2 class="mt-3 text-2xl font-extrabold tracking-tight sm:text-3xl">
        Permits &amp; local rules in {city.name}
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-brand-slate">{city.permitNote}</p>
    </div>
  </section>

  <!-- MARKDOWN BODY -->
  <section class="section">
    <div class="container-wide max-w-4xl">
      <article class="prose-body">
        <Content />
      </article>
    </div>
  </section>

  <!-- FAQ -->
  {city.faq.length > 0 && (
    <section class="section bg-white border-y border-brand-line">
      <div class="container-wide max-w-4xl">
        <span class="eyebrow">FAQ</span>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
          {city.name} HVAC questions
        </h2>
        <div class="mt-10 space-y-4">
          {city.faq.map((f) => (
            <details class="group rounded-2xl border border-brand-line bg-white p-6 shadow-sm">
              <summary class="flex cursor-pointer items-start justify-between gap-4 text-lg font-semibold text-brand-ink">
                <span>{f.q}</span>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-1 shrink-0 transition-transform group-open:rotate-180" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </summary>
              <p class="mt-4 leading-relaxed text-brand-slate">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- SERVICES OFFERED -->
  <section class="section">
    <div class="container-wide">
      <span class="eyebrow">Services</span>
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
        Services we offer in {city.name}
      </h2>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((s) => (
          <ServiceCard
            title={s.title}
            href={`/services/${s.slug}`}
            description={s.short}
            icon={s.icon}
            accent={s.accent}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- OTHER AREAS -->
  <section class="section bg-white border-y border-brand-line">
    <div class="container-wide max-w-4xl text-center">
      <span class="eyebrow">More areas</span>
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
        Other areas we serve
      </h2>
      <ul class="mt-8 flex flex-wrap justify-center gap-3">
        {otherCities.map((c) => (
          <li>
            <a href={`/service-areas/${c.slug}`} class="inline-flex items-center rounded-full border border-brand-line bg-white px-5 py-2.5 text-sm font-semibold text-brand-ink shadow-soft transition-colors hover:bg-brand-blue-50 hover:text-brand-blue-700">
              {c.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CTABanner
    heading={`Need service in ${city.name}?`}
    subheading={`Call ${config.business.phone} or book online — we'll be in ${city.name} this week.`}
  />
</BaseLayout>

<style>
  .prose-body :global(h2) {
    font-size: 1.875rem; line-height: 1.15; font-weight: 800; letter-spacing: -0.02em;
    color: #0E1320; margin: 2rem 0 1rem;
  }
  .prose-body :global(h3) {
    font-size: 1.375rem; line-height: 1.25; font-weight: 700; letter-spacing: -0.01em;
    color: #0E1320; margin: 1.75rem 0 0.75rem;
  }
  .prose-body :global(p) {
    font-size: 1.0625rem; line-height: 1.7; color: #3A4256; margin: 0 0 1rem;
  }
  .prose-body :global(ul), .prose-body :global(ol) {
    padding-left: 1.5rem; margin: 0 0 1.25rem;
    font-size: 1.0625rem; line-height: 1.7; color: #3A4256;
  }
  .prose-body :global(li) { margin: 0 0 0.5rem; }
  .prose-body :global(a) {
    color: #0858AC; font-weight: 600; text-decoration: underline; text-underline-offset: 3px;
  }
  .prose-body :global(strong) { color: #0E1320; font-weight: 700; }
</style>
