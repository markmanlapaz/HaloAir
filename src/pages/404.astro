---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Logo from '~/components/Logo.astro';
import config from '~/data/business-config.json';
---
<BaseLayout
  title="Page Not Found (404) — Halo Air"
  description="The page you're looking for doesn't exist. Try our services, service areas, or book a visit."
  canonicalPath="/404"
>
  <section class="section pt-20">
    <div class="container-wide max-w-3xl text-center">
      <Logo variant="mark" height={96} on="light" class="mx-auto" />

      <p class="mt-8 text-sm font-bold uppercase tracking-[0.25em] text-brand-orange-600">Error 404</p>
      <h1 class="mt-3 text-5xl font-extrabold tracking-tight sm:text-6xl">
        Lost a page somewhere.
      </h1>
      <p class="mt-5 text-lg text-brand-slate">
        The page you're looking for doesn't exist — maybe the link moved,
        maybe we never had it. Try one of these instead:
      </p>

      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        <a href="/services" class="rounded-2xl border border-brand-line bg-white p-6 text-left shadow-soft transition-all hover:-translate-y-1 hover:shadow-glow-blue">
          <p class="text-xs font-semibold uppercase tracking-wider text-brand-blue-700">Services</p>
          <p class="mt-2 text-lg font-bold text-brand-ink">See what we do</p>
          <p class="mt-1 text-sm text-brand-slate">AC, furnace, water heater, maintenance, after-hours service.</p>
        </a>
        <a href="/service-areas" class="rounded-2xl border border-brand-line bg-white p-6 text-left shadow-soft transition-all hover:-translate-y-1 hover:shadow-glow-blue">
          <p class="text-xs font-semibold uppercase tracking-wider text-brand-blue-700">Service areas</p>
          <p class="mt-2 text-lg font-bold text-brand-ink">Where we cover</p>
          <p class="mt-1 text-sm text-brand-slate">Edmonton + 7 surrounding cities.</p>
        </a>
        <a href="/blog" class="rounded-2xl border border-brand-line bg-white p-6 text-left shadow-soft transition-all hover:-translate-y-1 hover:shadow-glow-blue">
          <p class="text-xs font-semibold uppercase tracking-wider text-brand-orange-600">Guides</p>
          <p class="mt-2 text-lg font-bold text-brand-ink">Read the blog</p>
          <p class="mt-1 text-sm text-brand-slate">Cost guides, rebate info, decision frameworks.</p>
        </a>
        <a href="/book" class="rounded-2xl border border-brand-line bg-white p-6 text-left shadow-soft transition-all hover:-translate-y-1 hover:shadow-glow-blue">
          <p class="text-xs font-semibold uppercase tracking-wider text-brand-orange-600">Booking</p>
          <p class="mt-2 text-lg font-bold text-brand-ink">Book a visit</p>
          <p class="mt-1 text-sm text-brand-slate">Same-day service when you call before noon.</p>
        </a>
      </div>

      <div class="mt-12 flex flex-wrap justify-center gap-3">
        <a href="/" class="btn-primary">Back to home</a>
        <a href={`tel:${config.business.phoneE164}`} class="btn-ghost">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
          </svg>
          Call {config.business.phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
