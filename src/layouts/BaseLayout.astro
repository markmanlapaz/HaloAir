---
// =============================================================================
// BaseLayout.astro
// Single source of truth for <head>, SEO meta, JSON-LD, and page chrome.
// =============================================================================
import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import config from '~/data/business-config.json';
import {
  hvacBusinessSchema,
  breadcrumbListSchema,
  type BreadcrumbItem,
} from '~/lib/schema';

export interface Props {
  title: string;
  description: string;
  /** Path-only canonical (e.g. "/about"). The origin comes from astro.config.mjs `site`. */
  canonicalPath?: string;
  /** OG image URL — defaults to the brand-wide share image. */
  ogImage?: string;
  /** Inject extra JSON-LD on a per-page basis (Service, FAQPage, Article, etc.). */
  extraSchema?: Record<string, unknown> | Record<string, unknown>[];
  /** Set true on the homepage only — adds WebSite schema. */
  isHome?: boolean;
  /** Breadcrumb items for this page. When provided, BreadcrumbList JSON-LD is auto-emitted. */
  breadcrumbs?: BreadcrumbItem[];
  /** Override the default site name in <title> suffix. */
  titleSuffix?: string;
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  ogImage = '/og-image.jpg',
  extraSchema,
  isHome = false,
  breadcrumbs,
  titleSuffix,
} = Astro.props;

const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://example.com';
const canonical = `${site}${canonicalPath}`;
const absoluteOg = ogImage.startsWith('http') ? ogImage : `${site}${ogImage}`;

// Compose <title>. Pages can pass a full title; we don't double-append the
// brand name if it's already there.
const fullTitle = title.includes('Halo Air')
  ? title
  : `${title} | ${titleSuffix ?? config.business.shortName}`;

// ---------------------------------------------------------------------------
// Assemble the JSON-LD graph for this page:
//   - HVACBusiness (always, from schema lib)
//   - WebSite (home only)
//   - BreadcrumbList (when breadcrumbs prop is provided)
//   - Anything the page contributes via extraSchema
// ---------------------------------------------------------------------------
const schemaGraph: unknown[] = [hvacBusinessSchema(Astro.site, absoluteOg)];

if (isHome) {
  schemaGraph.push({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': `${site}/#website`,
    url: site,
    name: config.business.shortName,
    publisher: { '@id': `${site}/#business` },
  });
}

if (breadcrumbs && breadcrumbs.length > 0) {
  schemaGraph.push(breadcrumbListSchema(Astro.site, breadcrumbs));
}

if (extraSchema) {
  if (Array.isArray(extraSchema)) schemaGraph.push(...extraSchema);
  else schemaGraph.push(extraSchema);
}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#1E90FF" />

    <!-- Favicons — SVG primary, PNG/ICO fallback for older browsers -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/png" href="/images/logo.png" />
    <link rel="apple-touch-icon" href="/images/logo.png" />

    <!-- Primary SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={config.business.shortName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={absoluteOg} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_CA" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOg} />

    <!-- Preconnects to shave font fetch time -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
    />

    <!-- JSON-LD structured data graph -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(schemaGraph.length === 1 ? schemaGraph[0] : schemaGraph)}
    />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
