---
import config from '~/data/business-config.json';
import Logo from '~/components/Logo.astro';
import { getCollection } from 'astro:content';

const year = new Date().getFullYear();
const phone = config.business.phone;
const phoneE164 = config.business.phoneE164;

// Build the Services column from the same content collections the pages use,
// grouped by category so the footer mirrors the site IA exactly.
const cats = await getCollection('serviceCategories');
const categories = cats
  .sort((a, b) => a.data.order - b.data.order)
  .map((c) => ({ slug: c.id, label: c.data.label }));

const allServices = await getCollection('services');
type SubLink = { category: string; slug: string; label: string; order: number };
const subByCategory: Record<string, SubLink[]> = Object.fromEntries(
  categories.map((c) => [c.slug, []])
);
const standaloneServices: SubLink[] = [];
for (const s of allServices) {
  if (s.id.includes('/')) {
    const [cat, slug] = s.id.split('/');
    if (!subByCategory[cat]) continue;
    subByCategory[cat].push({ category: cat, slug, label: s.data.title, order: s.data.order });
  } else {
    standaloneServices.push({ category: '', slug: s.id, label: s.data.title, order: s.data.order });
  }
}
for (const cat of Object.keys(subByCategory)) {
  subByCategory[cat].sort((a, b) => a.order - b.order);
}
standaloneServices.sort((a, b) => a.order - b.order);
---
<footer class="mt-24 rounded-t-[3rem] bg-brand-ink text-white/85">
  <div class="container-wide grid gap-12 py-16 sm:grid-cols-2 lg:grid-cols-4">
    <!-- Brand column -->
    <div>
      <Logo variant="full" height={72} on="dark" />
      <p class="mt-5 text-sm leading-relaxed text-white/70">
        {config.business.tagline}. Award-winning heating, cooling, plumbing &amp;
        gas work serving the Edmonton metro area — 15 years of experience on
        every call.
      </p>
      <a href={`tel:${phoneE164}`} class="mt-5 inline-flex items-center gap-2 text-brand-orange-500 font-semibold hover:text-white">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
        </svg>
        {phone}
      </a>
    </div>

    <!-- Services column — grouped by category -->
    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Services</h3>
      <div class="mt-4 space-y-4 text-sm">
        {categories.map((c) => (
          <div>
            <a href={`/services/${c.slug}`} class="block font-semibold text-white hover:text-brand-orange-500">
              {c.label}
            </a>
            <ul class="mt-2 space-y-1 pl-3">
              {subByCategory[c.slug].map((s) => (
                <li>
                  <a href={`/services/${s.category}/${s.slug}`} class="text-white/70 transition-colors hover:text-white">
                    {s.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
        {standaloneServices.length > 0 && (
          <ul class="space-y-1">
            {standaloneServices.map((s) => (
              <li>
                <a href={`/services/${s.slug}`} class="font-semibold text-brand-orange-500 transition-colors hover:text-white">
                  {s.label}
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>

    <!-- Areas column -->
    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Service Areas</h3>
      <ul class="mt-4 space-y-2 text-sm">
        {config.serviceAreas.map((city) => (
          <li class="text-white/70">{city}</li>
        ))}
      </ul>
    </div>

    <!-- Company column -->
    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Company</h3>
      <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/about" class="text-white/70 hover:text-white">About</a></li>
        <li><a href="/book" class="text-white/70 hover:text-white">Book Service</a></li>
        <li><a href="/contact" class="text-white/70 hover:text-white">Contact</a></li>
        <li><a href="/blog" class="text-white/70 hover:text-white">Blog</a></li>
        <li><a href="/privacy" class="text-white/70 hover:text-white">Privacy</a></li>
        <li><a href="/terms" class="text-white/70 hover:text-white">Terms</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container-wide flex flex-col items-start justify-between gap-3 py-6 text-xs text-white/55 sm:flex-row sm:items-center">
      <p>&copy; {year} {config.business.name}. All rights reserved.</p>
      <p>Licensed &amp; insured in Alberta &middot; Serving Edmonton &amp; area</p>
    </div>
  </div>
</footer>
