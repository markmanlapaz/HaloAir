---
import config from '~/data/business-config.json';

export interface Props {
  heading?: string;
  subheading?: string;
}

const {
  heading = 'Comfort issue? We\'ll fix it.',
  subheading = 'Book online in under a minute, or call us direct.',
} = Astro.props;
---
<section class="section">
  <div class="container-wide">
    <div class="relative overflow-hidden rounded-[2.5rem] bg-gradient-to-br from-brand-blue-700 via-brand-blue-600 to-brand-orange-500 p-10 text-white shadow-soft sm:p-16">
      <!-- Soft halo decoration matching the logo's swirl -->
      <span aria-hidden="true" class="absolute -right-20 -top-20 h-72 w-72 rounded-full bg-white/10 blur-3xl"></span>
      <span aria-hidden="true" class="absolute -left-16 -bottom-16 h-64 w-64 rounded-full bg-brand-orange-600/40 blur-3xl"></span>

      <div class="relative grid items-center gap-8 lg:grid-cols-[1.4fr_1fr]">
        <div>
          <h2 class="text-3xl font-extrabold tracking-tight sm:text-4xl">{heading}</h2>
          <p class="mt-3 max-w-xl text-white/85">{subheading}</p>
        </div>
        <div class="flex flex-wrap gap-3 lg:justify-end">
          <a href="/book" class="btn-primary !bg-white !text-brand-orange-600 hover:!bg-brand-cream">
            Book Service
          </a>
          <a
            href={`tel:${config.business.phoneE164}`}
            class="btn-ghost !border-white/30 !bg-white/10 !text-white hover:!bg-white/20"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
            </svg>
            {config.business.phone}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
