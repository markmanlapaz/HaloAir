---
// =============================================================================
// ContactForm.astro
//
// Lightweight contact form (4 fields) — for general questions, not service
// bookings. The BookingForm.astro file handles full service requests with
// dispatch-ready fields. This form just routes to email via Web3Forms.
//
// Mirrors the same Phase 2 swap pattern: change CONTACT_ENDPOINT to point
// at your Phase 2 API endpoint and remove the 4 hidden Web3Forms inputs.
// =============================================================================
import config from '~/data/business-config.json';
---
<section class="card mx-auto max-w-2xl" aria-labelledby="contact-form-heading">
  <header class="mb-8">
    <span class="eyebrow">Send a message</span>
    <h2 id="contact-form-heading" class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
      Got a question?
    </h2>
    <p class="mt-2 text-brand-slate">
      For service bookings, use the <a href="/book" class="font-semibold text-brand-blue-700 hover:underline">booking form</a>.
      For general questions, drop us a note and we'll reply within 1 business day.
    </p>
  </header>

  <form id="contact-form" method="POST" novalidate class="space-y-5">
    <!-- Web3Forms hidden inputs (Phase 1 only — Phase 2 API removes these) -->
    <input type="hidden" name="access_key" value="" id="contact-web3forms-key" />
    <input type="hidden" name="subject" value="New contact message — Halo Air" />
    <input type="hidden" name="from_name" value="Halo Air Website" />
    <!-- Honeypot anti-spam -->
    <input
      type="checkbox" name="botcheck" tabindex="-1" autocomplete="off"
      style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;"
      aria-hidden="true"
    />

    <div class="grid gap-5 sm:grid-cols-2">
      <div>
        <label for="contact_name" class="mb-1.5 block text-sm font-semibold">Name *</label>
        <input id="contact_name" name="name" type="text" autocomplete="name" required
          class="w-full rounded-2xl border border-brand-line bg-white px-4 py-3 text-base shadow-sm focus:border-brand-blue-600" />
      </div>
      <div>
        <label for="contact_email" class="mb-1.5 block text-sm font-semibold">Email *</label>
        <input id="contact_email" name="email" type="email" autocomplete="email" required
          class="w-full rounded-2xl border border-brand-line bg-white px-4 py-3 text-base shadow-sm focus:border-brand-blue-600" />
      </div>
    </div>

    <div>
      <label for="contact_phone" class="mb-1.5 block text-sm font-semibold">
        Phone <span class="text-brand-slate font-normal">(optional)</span>
      </label>
      <input id="contact_phone" name="phone" type="tel" autocomplete="tel"
        class="w-full rounded-2xl border border-brand-line bg-white px-4 py-3 text-base shadow-sm focus:border-brand-blue-600" />
    </div>

    <div>
      <label for="contact_message" class="mb-1.5 block text-sm font-semibold">Message *</label>
      <textarea id="contact_message" name="message" rows="5" required
        placeholder="What can we help with? Quotes, general questions, feedback — all welcome."
        class="w-full rounded-2xl border border-brand-line bg-white px-4 py-3 text-base shadow-sm focus:border-brand-blue-600"
      ></textarea>
    </div>

    <p id="contact-form-status" class="text-sm" role="status" aria-live="polite"></p>

    <button type="submit" id="contact-submit" class="btn-primary w-full sm:w-auto">
      <span data-label="default">Send message</span>
      <span data-label="loading" class="hidden">Sending…</span>
    </button>

    <p class="text-xs text-brand-slate">
      By submitting, you agree to be contacted about your message. We never share your info. See <a href="/privacy" class="underline">Privacy</a>.
    </p>
  </form>
</section>

<script>
  // Single Phase 2 swap point.
  const CONTACT_ENDPOINT = 'https://api.web3forms.com/submit';
  const WEB3FORMS_KEY = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('contact-form-status');
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const keyInput = document.getElementById('contact-web3forms-key') as HTMLInputElement | null;

  if (form && status && submitBtn && keyInput) {
    keyInput.value = WEB3FORMS_KEY;

    const setStatus = (msg: string, tone: 'idle' | 'ok' | 'err') => {
      status.textContent = msg;
      status.className = 'text-sm ' + ({
        idle: 'text-brand-slate',
        ok: 'text-green-700',
        err: 'text-red-700',
      }[tone]);
    };

    const setLoading = (loading: boolean) => {
      submitBtn.disabled = loading;
      submitBtn.querySelector('[data-label="default"]')?.classList.toggle('hidden', loading);
      submitBtn.querySelector('[data-label="loading"]')?.classList.toggle('hidden', !loading);
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        setStatus('Please fill in the required fields.', 'err');
        return;
      }
      if (!WEB3FORMS_KEY) {
        setStatus('Form is not yet configured. Please call 780-224-0024 or email haloairhvac@gmail.com directly.', 'err');
        return;
      }
      setLoading(true);
      setStatus('Sending your message…', 'idle');
      try {
        const res = await fetch(CONTACT_ENDPOINT, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && (data as { success?: boolean }).success !== false) {
          form.reset();
          setStatus("Thanks — we got your message and we'll reply within 1 business day.", 'ok');
        } else {
          throw new Error((data as { message?: string }).message ?? 'Submission failed');
        }
      } catch (err) {
        console.error('[ContactForm] submit failed', err);
        setStatus('Something went wrong. Please call 780-224-0024.', 'err');
      } finally {
        setLoading(false);
      }
    });
  }
</script>
