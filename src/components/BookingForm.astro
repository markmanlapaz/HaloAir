---
// =============================================================================
// BookingForm.astro
//
// PHASE 2: posts directly to the AI dispatcher's /api/book endpoint.
// The dispatcher validates with Zod, runs Claude triage, checks Google Calendar
// availability, and emails the owner with one-tap approval buttons.
//
// The BOOKING_ENDPOINT constant below is the single environment-dependent value:
//   - local dev:  http://localhost:3000/api/book
//   - production: https://<railway-app-url>/api/book
//
// Customer-facing fallback when the dispatcher is unreachable: the catch block
// in the submit handler shows the owner's phone number so customers can call
// directly.
//
// No localStorage / sessionStorage anywhere — booking ID lives in component
// state via a hidden input, generated client-side at form mount.
// =============================================================================
import config from '~/data/business-config.json';

// Render the service-type select as <optgroup>s per category so customers
// pick the right sub-service. Standalone (after-hours) lives in its own group
// at the bottom. The submitted value is the sub-service slug (e.g.
// "ac-repair") — the AI dispatcher maps that to a duration/buffer pair from
// business-config.json.
const categoryGroups = Object.entries(config.serviceCategories).map(([key, cat]) => ({
  key,
  label: cat.label,
  options: Object.entries(cat.services).map(([slug, s]) => ({ value: slug, label: s.label })),
}));
const standaloneGroup = {
  label: 'Other',
  options: Object.entries(config.standaloneServices).map(([slug, s]) => ({ value: slug, label: s.label })),
};
---
<section class="card mx-auto max-w-3xl" aria-labelledby="booking-form-heading">
  <header class="mb-8">
    <span class="eyebrow">Book Service</span>
    <h2 id="booking-form-heading" class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
      Request a visit
    </h2>
    <p class="mt-2 text-brand-slate">
      Fill out the form and we'll confirm your appointment within one business
      day. Need help outside hours? Call or text
      <a href={`tel:${config.business.phoneE164}`} class="font-semibold text-brand-orange-600 hover:underline">
        {config.business.phone}
      </a> — after-hours service is available on request.
    </p>
  </header>

  <form
    id="booking-form"
    method="POST"
    novalidate
    class="space-y-5"
    data-form-name="HaloAir Booking Request"
  >
    <!-- Honeypot anti-spam: bots fill this; humans don't see it. The
         dispatcher ignores the field today; we keep it on the form so we can
         start rejecting truthy submissions server-side if abuse appears. -->
    <input
      type="checkbox"
      name="botcheck"
      tabindex="-1"
      autocomplete="off"
      style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;"
      aria-hidden="true"
    />

    <!-- Client-generated booking ID. Hidden but submitted with the payload so
         the AI dispatcher can correlate logs across systems. -->
    <input type="hidden" name="booking_id" id="booking-id" value="" />

    <div class="grid gap-5 sm:grid-cols-2">
      <div>
        <label for="full_name" class="mb-1.5 block text-sm font-semibold">Full name *</label>
        <input
          id="full_name"
          name="full_name"
          type="text"
          autocomplete="name"
          required
          class="w-full rounded-2xl border border-brand-line bg-white px-4 py-3 text-base shadow-sm focus:border-brand-blue-600"
        />
      </div>
      <div>
        <label for="phone" class="mb-1.5 block text-sm font-semibold">Phone *</label>
        <input
          id="phone"
          name="phone"
          type="tel"
          autocomplete="tel"
          required
          pattern="[\d\s\-\(\)\+]{10,}"
          placeholder="(780) 555-1234"
          class="w-full rounded-2xl border border-brand-line bg-white px-4 py-3 text-base shadow-sm focus:border-brand-blue-600"
        />
      </div>
    </div>

    <div>
      <label for="email" class="mb-1.5 block text-sm font-semibold">Email *</label>
      <input
        id="email"
        name="email"
        type="email"
        autocomplete="email"
        required
        class="w-full rounded-2xl border border-brand-line bg-white px-4 py-3 text-base shadow-sm focus:border-brand-blue-600"
      />
    </div>

    <div>
      <label for="address" class="mb-1.5 block text-sm font-semibold">Service address *</label>
      <input
        id="address"
        name="address"
        type="text"
        autocomplete="street-address"
        required
        placeholder="Street, City, Postal Code"
        class="w-full rounded-2xl border border-brand-line bg-white px-4 py-3 text-base shadow-sm focus:border-brand-blue-600"
      />
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      <div>
        <label for="service_type" class="mb-1.5 block text-sm font-semibold">Service type *</label>
        <select
          id="service_type"
          name="service_type"
          required
          class="w-full rounded-2xl border border-brand-line bg-white px-4 py-3 text-base shadow-sm focus:border-brand-blue-600"
        >
          <option value="">— Choose a service —</option>
          {categoryGroups.map((g) => (
            <optgroup label={g.label}>
              {g.options.map((o) => (
                <option value={o.value}>{o.label}</option>
              ))}
            </optgroup>
          ))}
          <optgroup label={standaloneGroup.label}>
            {standaloneGroup.options.map((o) => (
              <option value={o.value}>{o.label}</option>
            ))}
            <option value="inquiry">General inquiry</option>
            <option value="other">Something else</option>
          </optgroup>
        </select>
      </div>
      <div id="urgency-wrap">
        <label for="urgency" class="mb-1.5 block text-sm font-semibold">Urgency</label>
        <select
          id="urgency"
          name="urgency"
          class="w-full rounded-2xl border border-brand-line bg-white px-4 py-3 text-base shadow-sm focus:border-brand-blue-600"
        >
          <option value="">— How urgent? —</option>
          <option value="emergency">Emergency (no heat / no cool)</option>
          <option value="within-48h">Within 48 hours</option>
          <option value="flexible">Flexible — anytime this week</option>
        </select>
      </div>
    </div>

    <!-- Install-only home detail fields. Hidden by default; revealed by the
         script below when service_type is a furnace/AC installation. All
         optional — they help with quoting but never block a submission. -->
    <fieldset
      id="install-details"
      class="hidden space-y-5 rounded-2xl border border-brand-line bg-brand-cream/40 p-5"
      aria-hidden="true"
    >
      <legend class="px-2 text-sm font-semibold text-brand-slate">
        About your home <span class="font-normal">(helps us prep an accurate quote — all optional)</span>
      </legend>

      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="home_age" class="mb-1.5 block text-sm font-semibold">Age of home</label>
          <select
            id="home_age"
            name="home_age"
            class="w-full rounded-2xl border border-brand-line bg-white px-4 py-3 text-base shadow-sm focus:border-brand-blue-600"
          >
            <option value="">— Select —</option>
            <option value="under-10">Under 10 years</option>
            <option value="10-25">10–25 years</option>
            <option value="25-50">25–50 years</option>
            <option value="50-plus">50+ years</option>
            <option value="unsure">Not sure</option>
          </select>
        </div>
        <div>
          <label for="lot_type" class="mb-1.5 block text-sm font-semibold">Lot type</label>
          <select
            id="lot_type"
            name="lot_type"
            class="w-full rounded-2xl border border-brand-line bg-white px-4 py-3 text-base shadow-sm focus:border-brand-blue-600"
          >
            <option value="">— Select —</option>
            <option value="regular">Regular lot</option>
            <option value="zero-lot">Zero lot line</option>
            <option value="unsure">Not sure</option>
          </select>
        </div>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="basement_type" class="mb-1.5 block text-sm font-semibold">Basement</label>
          <select
            id="basement_type"
            name="basement_type"
            class="w-full rounded-2xl border border-brand-line bg-white px-4 py-3 text-base shadow-sm focus:border-brand-blue-600"
          >
            <option value="">— Select —</option>
            <option value="finished">Finished</option>
            <option value="unfinished">Unfinished</option>
            <option value="crawlspace">Crawlspace</option>
            <option value="slab-or-none">Slab / none</option>
            <option value="unsure">Not sure</option>
          </select>
        </div>
        <div>
          <label for="legal_suite" class="mb-1.5 block text-sm font-semibold">Legal suite?</label>
          <select
            id="legal_suite"
            name="legal_suite"
            class="w-full rounded-2xl border border-brand-line bg-white px-4 py-3 text-base shadow-sm focus:border-brand-blue-600"
          >
            <option value="">— Select —</option>
            <option value="no">No</option>
            <option value="yes">Yes</option>
            <option value="unsure">Not sure</option>
          </select>
        </div>
      </div>

      <div>
        <label for="square_footage" class="mb-1.5 block text-sm font-semibold">
          Approx. square footage <span class="text-brand-slate font-normal">(optional — approx is fine)</span>
        </label>
        <input
          id="square_footage"
          name="square_footage"
          type="number"
          min="300"
          inputmode="numeric"
          placeholder="e.g. 1800"
          class="w-full rounded-2xl border border-brand-line bg-white px-4 py-3 text-base shadow-sm focus:border-brand-blue-600"
        />
      </div>
    </fieldset>

    <div class="grid gap-5 sm:grid-cols-2">
      <div>
        <label for="preferred_date" class="mb-1.5 block text-sm font-semibold">
          Preferred date <span class="text-brand-slate font-normal">(optional)</span>
        </label>
        <input
          id="preferred_date"
          name="preferred_date"
          type="date"
          class="w-full rounded-2xl border border-brand-line bg-white px-4 py-3 text-base shadow-sm focus:border-brand-blue-600"
        />
      </div>
      <div>
        <label for="preferred_window" class="mb-1.5 block text-sm font-semibold">Preferred time</label>
        <select
          id="preferred_window"
          name="preferred_window"
          class="w-full rounded-2xl border border-brand-line bg-white px-4 py-3 text-base shadow-sm focus:border-brand-blue-600"
        >
          <option value="flexible">Flexible</option>
          <option value="morning">Morning (8a–12p)</option>
          <option value="afternoon">Afternoon (12p–5p)</option>
          <option value="after-hours">After hours (by request)</option>
        </select>
      </div>
    </div>

    <div>
      <label for="problem_description" class="mb-1.5 block text-sm font-semibold">
        Tell us what's happening *
      </label>
      <textarea
        id="problem_description"
        name="problem_description"
        rows="4"
        required
        placeholder="e.g. Furnace blowing cold air, started yesterday afternoon. 2-storey home, 18 yrs old."
        class="w-full rounded-2xl border border-brand-line bg-white px-4 py-3 text-base shadow-sm focus:border-brand-blue-600"
      ></textarea>
    </div>

    <!-- Live region: screen-reader-announced form status. -->
    <p id="form-status" class="text-sm" role="status" aria-live="polite"></p>

    <button
      type="submit"
      id="booking-submit"
      class="btn-primary w-full sm:w-auto"
    >
      <span data-label="default">Request Booking</span>
      <span data-label="loading" class="hidden">Sending…</span>
    </button>

    <p class="text-xs text-brand-slate">
      By submitting, you agree to be contacted about your service request. We
      never share your information. See our <a href="/privacy" class="underline">Privacy Policy</a>.
    </p>
  </form>
</section>

<script>
  // ---------------------------------------------------------------------------
  // The single environment-dependent value in this file. Change to the Railway
  // URL when deploying. Field names already match what the dispatcher expects.
  // ---------------------------------------------------------------------------
  const BOOKING_ENDPOINT = 'https://haloair-dispatcher-production.up.railway.app/api/book';

  const form = document.getElementById('booking-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status');
  const submitBtn = document.getElementById('booking-submit') as HTMLButtonElement | null;
  const idInput = document.getElementById('booking-id') as HTMLInputElement | null;

  if (form && status && submitBtn && idInput) {
    // Generate a booking ID at mount: BK-{timestamp36}-{random6}. The
    // dispatcher uses this to correlate logs, calendar events, and emails.
    const id = `BK-${Date.now().toString(36).toUpperCase()}-${Math.random().toString(36).slice(2, 8).toUpperCase()}`;
    idInput.value = id;

    // Prefill from hero quick-form handoff (?name=&phone=&service=).
    // The hero form on the homepage just collects these three fields and
    // navigates here — we carry them over so the visitor doesn't retype.
    const params = new URLSearchParams(window.location.search);
    const nameInput = document.getElementById('full_name') as HTMLInputElement | null;
    const phoneInput = document.getElementById('phone') as HTMLInputElement | null;
    const serviceSelect = document.getElementById('service_type') as HTMLSelectElement | null;
    let prefilled = false;
    const nameParam = params.get('name');
    if (nameInput && nameParam && !nameInput.value) {
      nameInput.value = nameParam;
      prefilled = true;
    }
    const phoneParam = params.get('phone');
    if (phoneInput && phoneParam && !phoneInput.value) {
      phoneInput.value = phoneParam;
      prefilled = true;
    }
    const serviceParam = params.get('service');
    if (serviceSelect && serviceParam) {
      const match = Array.from(serviceSelect.options).some((o) => o.value === serviceParam);
      if (match) {
        serviceSelect.value = serviceParam;
        prefilled = true;
      }
    }
    if (prefilled) {
      form.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // Conditional "About your home" fieldset: shown only for install services.
    // Clearing values on hide prevents a user who switched away from submitting
    // stale install data they can no longer see.
    const INSTALL_SERVICES = new Set(['furnace-installation', 'ac-installation']);
    const installFieldset = document.getElementById('install-details') as HTMLFieldSetElement | null;

    const syncInstallVisibility = () => {
      if (!installFieldset || !serviceSelect) return;
      const show = INSTALL_SERVICES.has(serviceSelect.value);
      installFieldset.classList.toggle('hidden', !show);
      installFieldset.setAttribute('aria-hidden', show ? 'false' : 'true');
      if (!show) {
        installFieldset.querySelectorAll('select, input').forEach((el) => {
          (el as HTMLInputElement | HTMLSelectElement).value = '';
        });
      }
    };

    serviceSelect?.addEventListener('change', syncInstallVisibility);
    syncInstallVisibility();

    // Hide urgency for general inquiries — they're not booking a service window.
    const urgencyWrap = document.getElementById('urgency-wrap');
    const urgencySelect = document.getElementById('urgency') as HTMLSelectElement | null;
    const syncUrgencyVisibility = () => {
      if (!urgencyWrap || !urgencySelect || !serviceSelect) return;
      const hide = serviceSelect.value === 'inquiry';
      urgencyWrap.classList.toggle('hidden', hide);
      if (hide) urgencySelect.value = '';
    };
    serviceSelect?.addEventListener('change', syncUrgencyVisibility);
    syncUrgencyVisibility();

    const setStatus = (msg: string, tone: 'idle' | 'ok' | 'err') => {
      status.textContent = msg;
      status.className = 'text-sm ' + ({
        idle: 'text-brand-slate',
        ok: 'text-green-700',
        err: 'text-red-700',
      }[tone]);
    };

    const setLoading = (loading: boolean) => {
      submitBtn.disabled = loading;
      submitBtn.querySelector('[data-label="default"]')?.classList.toggle('hidden', loading);
      submitBtn.querySelector('[data-label="loading"]')?.classList.toggle('hidden', !loading);
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Use the browser's native constraint validation, then layer our own UX.
      if (!form.checkValidity()) {
        form.reportValidity();
        setStatus('Please fill in the required fields.', 'err');
        return;
      }

      setLoading(true);
      setStatus('Sending your request…', 'idle');

      try {
        const fd = new FormData(form);
        const res = await fetch(BOOKING_ENDPOINT, {
          method: 'POST',
          body: fd,
          headers: { Accept: 'application/json' },
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && (data as { ok?: boolean }).ok === true) {
          form.reset();
          // Restore the freshly-reset booking ID so the user sees it confirmed.
          idInput.value = id;
          // form.reset() clears service_type but doesn't fire `change` —
          // re-hide the install fieldset manually.
          syncInstallVisibility();
          syncUrgencyVisibility();
          setStatus(
            `Got it — we'll be in touch shortly. Reference: ${id}`,
            'ok',
          );
        } else {
          throw new Error((data as { message?: string }).message ?? 'Submission failed');
        }
      } catch (err) {
        console.error('[BookingForm] submit failed', err);
        setStatus(
          'Something went wrong. Please call 780-224-0024 — we want to help.',
          'err',
        );
      } finally {
        setLoading(false);
      }
    });
  }
</script>
